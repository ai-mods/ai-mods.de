---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

{
  /*
  Placed as the last child of <main>. The sticky wrapper pins the button to the
  viewport bottom while scrolling, but it can never leave <main> — so it always
  stops above the footer instead of covering it.
*/
}
<div class="wrap">
  <button class="totop" aria-label={t("totop.label")}>
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 19V5"></path>
      <path d="M5 12l7-7 7 7"></path>
    </svg>
  </button>
</div>

<script>
  const button = document.querySelector<HTMLButtonElement>(".totop");

  if (button) {
    const toggle = () =>
      button.classList.toggle("visible", window.scrollY > 400);

    window.addEventListener("scroll", toggle, { passive: true });
    toggle();

    button.addEventListener("click", () =>
      window.scrollTo({ top: 0, behavior: "smooth" }),
    );
  }
</script>

<style>
  .wrap {
    position: sticky;
    bottom: 24px;
    z-index: 40;
    height: 0;
    display: flex;
    justify-content: flex-end;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 40px;
    pointer-events: none;
  }

  .totop {
    pointer-events: auto;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border-btn);
    background: var(--surface);
    color: var(--text-soft);
    cursor: pointer;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 150ms ease,
      visibility 150ms ease,
      border-color 150ms ease;
  }

  .totop.visible {
    opacity: 1;
    visibility: visible;
  }

  .totop:hover {
    border-color: var(--acc);
    color: var(--text);
  }

  @media (max-width: 768px) {
    .wrap {
      padding: 0 20px;
    }
  }
</style>
