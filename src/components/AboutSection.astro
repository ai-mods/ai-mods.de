---
import { Image } from "astro:assets";
import SectionShell from "./SectionShell.astro";
import FactRow from "./FactRow.astro";
import { siteConfig } from "../config";
import { useTranslations, type Lang } from "../i18n/utils";
import portrait from "../assets/chris-portrait.webp";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<SectionShell id="ueber" kicker={t("about.kicker")}>
  <h2 class="heading">{t("about.heading")}</h2>
  <p class="subheading">{t("about.subheading")}</p>

  <div class="grid">
    <div class="text">
      <p class="paragraph">{t("about.p1")}</p>
      <ul class="credentials">
        <li>{t("about.credential1")}</li>
        <li>{t("about.credential2")}</li>
      </ul>

      <div class="portrait-row">
        <Image
          class="portrait"
          src={portrait}
          alt={t("about.portraitAlt")}
          width={280}
          densities={[1, 2]}
        />
        <p class="quote">{t("about.quote")}</p>
      </div>
    </div>

    <div class="facts">
      <FactRow
        label={t("about.fact.roleLabel")}
        value={t("about.fact.roleValue")}
      />
      <FactRow
        label={t("about.fact.locationLabel")}
        value={t("about.fact.locationValue")}
      />
      <FactRow
        label={t("about.fact.languagesLabel")}
        value={t("about.fact.languagesValue")}
      />
      <FactRow
        label={t("about.fact.workModeLabel")}
        value={t("about.fact.workModeValue")}
      />
      {
        siteConfig.available && (
          <FactRow
            label={t("about.fact.availableLabel")}
            value={`${t("about.fact.availablePrefix")} ${siteConfig.availableFrom}`}
            accent
          />
        )
      }
      <FactRow
        label={t("about.fact.openLabel")}
        value={t("about.fact.openValue")}
        noBorder
      />
    </div>
  </div>
</SectionShell>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: start;
  }

  .heading {
    margin: 0 0 10px;
    font-family: var(--font-mono);
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .subheading {
    margin: 0 0 40px;
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-dim);
  }

  .paragraph {
    margin: 0 0 16px;
    max-width: 640px;
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .credentials {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 2;
    color: var(--text-muted);
  }

  .credentials li::before {
    content: "› ";
    color: var(--text-ghost);
  }

  .facts {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .portrait-row {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 32px;
  }

  .portrait {
    width: 110px;
    height: 110px;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    border: 4px solid var(--acc);
    background: var(--bg-portrait);
    object-fit: cover;
  }

  .quote {
    margin: 0;
    max-width: 280px;
    font-family: var(--font-mono);
    font-size: 21px;
    line-height: 1.5;
    color: var(--acc);
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .heading {
      font-size: 32px;
    }

    .subheading {
      font-size: 17px;
    }
  }
</style>
