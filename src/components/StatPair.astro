---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div>
  <div class="value">{value}</div>
  <div class="label">{label}</div>
</div>

<style>
  .value {
    font-family: var(--font-mono);
    font-size: 38px;
    font-weight: 600;
    color: var(--acc);
    letter-spacing: -0.02em;
  }

  .label {
    font-size: 13px;
    color: var(--text-faint);
  }
</style>
