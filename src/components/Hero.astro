---
import Button from "./Button.astro";
import { siteConfig } from "../config";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="band">
  <div class="hero">
    <div class="prompt-row">
      <span class="prompt">{t("hero.prompt")}</span>
      {
        siteConfig.available && (
          <span class="avail">
            {t("hero.availability")} {siteConfig.availableFrom}
          </span>
        )
      }
    </div>

    <h1 class="headline">
      {t("hero.headline")}<span class="cursor" aria-hidden="true"></span>
    </h1>

    <p class="tagline">{t("hero.tagline")}</p>

    <p class="intro">{t("hero.intro")}</p>

    <div class="buttons">
      <Button
        href={siteConfig.links.linkedin}
        label={t("hero.ctaPrimary")}
        variant="primary"
        external
      />
      <Button
        href={siteConfig.links.github}
        label={t("hero.ctaSecondary")}
        variant="secondary"
        external
      />
    </div>
  </div>
</div>

<style>
  .band {
    position: relative;
    isolation: isolate;
  }

  .band::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: radial-gradient(
      var(--border-btn) 1.2px,
      transparent 1.2px
    );
    background-size: 36px 36px;
    mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
    pointer-events: none;
  }

  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 110px 40px 90px;
    border-bottom: 1px solid var(--border);
  }

  .prompt-row {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .prompt {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--acc);
  }

  .avail {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--acc);
    border: 1px solid var(--acc-dim);
    background: var(--acc-dim);
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .headline {
    margin: 0 0 28px;
    font-family: var(--font-mono);
    font-size: 72px;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.02em;
    max-width: 940px;
  }

  .cursor {
    display: inline-block;
    width: 0.5em;
    height: 0.95em;
    background: var(--acc);
    vertical-align: -0.08em;
    margin-left: 0.12em;
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .tagline {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-soft);
  }

  .intro {
    margin: 0 0 40px;
    max-width: 680px;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .buttons {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 20px 64px;
    }

    .headline {
      font-size: 42px;
    }

    .buttons {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 48px;
    }
  }
</style>
